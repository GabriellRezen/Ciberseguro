generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  article
  guide
  faq
  warning
}

enum SeverityLevel {
  low
  medium
  high
}

enum AnalysisInputType {
  text
  image
  mixed
  quick_action
}

enum AnalysisStatus {
  pending
  processed
  failed
}

enum ReportType {
  cyberbullying
  harassment
  threat
  image_exposure
  impersonation
  other
}

enum ReportStatus {
  draft
  submitted
  archived
}

enum MessageRole {
  user
  assistant
  system
}

enum UserRole {
  user
  admin
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(user)

  reports      Report[]
  chatSessions ChatSession[]
  analyses     AnalysisRequest[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContentCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  contents    Content[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Content {
  id           String          @id @default(uuid())
  title        String
  slug         String          @unique
  summary      String?
  body         String
  type         ContentType
  isPublished  Boolean         @default(true)

  categoryId   String
  category     ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PspCenter {
  id                 String   @id @default(uuid())
  name               String   @unique
  address            String
  city               String
  district           String?
  latitude           Float
  longitude          Float
  phone              String?
  email              String?
  openingHours       String?
  supportsCybercrime Boolean  @default(false)
  notes              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SupportResource {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  type        String
  url         String?
  content     String?
  isPublished Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqItem {
  id          String   @id @default(uuid())
  question    String
  answer      String
  category    String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuickAction {
  id              String   @id @default(uuid())
  label           String
  slug            String   @unique
  description     String?
  priority        Int      @default(0)
  recommendedFlow String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChatSession {
  id         String        @id @default(uuid())
  userId     String?
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  status     String        @default("active")
  startedAt  DateTime      @default(now())
  endedAt    DateTime?

  messages   ChatMessage[]
}

model ChatMessage {
  id         String      @id @default(uuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role       MessageRole
  content    String
  intent     String?

  createdAt  DateTime    @default(now())
}

model AnalysisRequest {
  id                 String             @id @default(uuid())
  userId             String?
  user               User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  inputType          AnalysisInputType
  originalText       String?
  status             AnalysisStatus     @default(pending)
  severity           SeverityLevel?
  classification     String?
  aiSummary          String?
  recommendedActions Json?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  evidences          UploadedEvidence[]
  reports            Report[]
}

model UploadedEvidence {
  id                String          @id @default(uuid())
  analysisRequestId String
  analysisRequest   AnalysisRequest @relation(fields: [analysisRequestId], references: [id], onDelete: Cascade)

  fileUrl           String
  fileType          String
  mimeType          String?
  size              Int?
  originalName      String?

  createdAt         DateTime        @default(now())
}

model Report {
  id                String           @id @default(uuid())
  userId            String?
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  analysisRequestId String?
  analysisRequest   AnalysisRequest? @relation(fields: [analysisRequestId], references: [id], onDelete: SetNull)

  type              ReportType
  description       String
  isAnonymous       Boolean          @default(true)
  status            ReportStatus     @default(draft)

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}
